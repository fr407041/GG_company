{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Company Task Assignment",
  "type": "object",
  "required": [
    "task_id",
    "owner_role",
    "scope",
    "depends_on",
    "acceptance_criteria",
    "fallback_plan"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "owner_role": {
      "type": "string",
      "enum": [
        "research_agent",
        "synthesis_agent",
        "planner_agent",
        "executor_backend",
        "executor_frontend",
        "executor_docs",
        "reviewer_worker",
        "risk_reviewer",
        "decision_agent"
      ]
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "fallback_plan": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
