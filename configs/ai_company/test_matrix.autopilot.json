{
  "goal_id": "ai-company-autopilot",
  "cases": [
    {
      "case_id": "small_research_summary",
      "description": "A narrow research task should classify cleanly and complete without a meeting.",
      "expected_pipeline": "research_summary",
      "meeting_expected": false,
      "required_signals": ["task_classified", "pipeline_attached", "verify_completed"],
      "expected_alerts": [],
      "anti_goals": ["unnecessary_meeting", "oversized_prompt"]
    },
    {
      "case_id": "complex_research_conflict",
      "description": "A broader research task with conflicting evidence should trigger a bounded planning meeting.",
      "expected_pipeline": "research_conflict_resolution",
      "meeting_expected": true,
      "required_signals": ["meeting_started", "meeting_completed", "dispatch_split_tasks", "verify_completed"],
      "expected_alerts": [],
      "anti_goals": ["single_agent_guessing", "meeting_loop"]
    },
    {
      "case_id": "implementation_small",
      "description": "A small implementation task should use the implementation pipeline and include review before verify.",
      "expected_pipeline": "implementation_small",
      "meeting_expected": false,
      "required_signals": ["task_classified", "execute", "review", "verify_completed"],
      "expected_alerts": [],
      "anti_goals": ["research_pipeline_misroute"]
    },
    {
      "case_id": "failure_recovery_router_or_overflow",
      "description": "Known router or overflow pressure should trigger the failure recovery pipeline.",
      "expected_pipeline": "failure_recovery",
      "meeting_expected": true,
      "required_signals": ["failure_detected", "replan_or_recovery_started", "dispatch_recovery_task", "verify_completed"],
      "expected_alerts": ["router_error", "overflow_detected"],
      "anti_goals": ["infinite_retry", "silent_failure"]
    },
    {
      "case_id": "reasoning_heavy_output_pressure",
      "description": "A reasoning-heavy model that emits too much preamble should be detected and scoped down.",
      "expected_pipeline": "failure_recovery",
      "meeting_expected": true,
      "required_signals": ["failure_detected", "replan_or_recovery_started", "verify_completed"],
      "expected_alerts": ["overflow_detected"],
      "anti_goals": ["same_prompt_repeat", "unbounded_output"]
    },
    {
      "case_id": "router_partial_or_empty_response",
      "description": "Partial or empty router output should surface a router error and bounded retry path.",
      "expected_pipeline": "failure_recovery",
      "meeting_expected": true,
      "required_signals": ["failure_detected", "dispatch_recovery_task", "verify_completed"],
      "expected_alerts": ["router_error"],
      "anti_goals": ["false_success", "hang_forever"]
    },
    {
      "case_id": "false_success_no_real_change",
      "description": "A child task that reports success without producing evidence or artifacts should be blocked in review.",
      "expected_pipeline": "failure_recovery",
      "meeting_expected": true,
      "required_signals": ["review", "verify_completed"],
      "expected_alerts": ["artifact_missing"],
      "anti_goals": ["accept_empty_result"]
    },
    {
      "case_id": "replan_loop_guard",
      "description": "Repeated replan pressure should be bounded and escalated instead of looping endlessly.",
      "expected_pipeline": "failure_recovery",
      "meeting_expected": true,
      "required_signals": ["replan_or_recovery_started", "verify_completed"],
      "expected_alerts": ["replan_limit_reached"],
      "anti_goals": ["infinite_replan_loop"]
    }
  ]
}
